# Root .env for docker compose. Copy to `.env` and adjust:
#   cp .env.example .env

# The hostname whose DNS A/AAAA record points at the server
# (required by docker-compose.https.yml).
DOMAIN=player.example.com

# Contact address for Let's Encrypt (expiry notices). Optional but recommended.
ACME_EMAIL=you@example.com

# REQUIRED: signs the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: in-app password gate. When set, visitors must enter this password on a
# login screen before they can browse or watch. Leave empty for open access.
SITE_PASSWORD=

# Cross-Origin-Embedder-Policy: require-corp | credentialless | off
# This player uses WebCodecs (no SharedArrayBuffer), so 'off' is fine and safest.
COEP=off
