# Copy to .env and adjust. All values are optional except SESSION_SECRET in prod.

# Port the backend listens on
PORT=8080

# Secret used to sign the session cookie — set to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Cross-Origin-Embedder-Policy mode: require-corp | credentialless | off
# require-corp is safest on older Chromium (we proxy all cross-origin assets).
COEP=require-corp

# Override the desktop User-Agent sent to Bilibili if needed
# BILI_UA=Mozilla/5.0 ...

# Path to the built frontend (defaults to ../web/dist relative to the server)
# WEB_DIST=/app/web/dist
